# Environment variables - copy to .env or export in shell
# Values are already set in docker-compose.yml when using compose

DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/scheduler
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me
PORT=4000
WORKER_CONCURRENCY=5
POLL_INTERVAL_MS=500
TICK_INTERVAL_MS=1000
VITE_API_URL=http://localhost:4000

# Required only for single-service deployment (see docs/DEPLOYMENT.md)
# Leave unset for docker-compose / multi-service setup
TICK_SECRET=
TICK_MAX_JOBS=10